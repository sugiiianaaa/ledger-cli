#!/bin/sh

# Auto-format staged C# files before commit
STAGED_CS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.cs$')

if [ -z "$STAGED_CS_FILES" ]; then
    exit 0
fi

echo "Running dotnet format on staged files..."
dotnet format --include $STAGED_CS_FILES

# Re-stage the formatted files
echo "$STAGED_CS_FILES" | xargs git add

exit 0
